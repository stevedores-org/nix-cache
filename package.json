{
    "name": "nix-cache",
    "version": "1.0.0",
    "main": "src/index.ts",
    "scripts": {
        "build": "bun x wrangler deploy --dry-run",
        "deploy": "bun x wrangler deploy",
        "dev": "bun x wrangler dev",
        "test": "bun test",
        "lint": "bunx biome check src/",
        "lint:fix": "bunx biome check --write src/",
        "format": "bunx biome format src/",
        "format:check": "bunx biome check --linter-enabled=false src/",
        "typecheck": "bunx tsc --noEmit"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.4",
        "@cloudflare/workers-types": "^4.20240320.1",
        "@types/bun": "^1.3.9",
        "typescript": "^5.4.3",
        "wrangler": "^4.68.1"
    }
}
